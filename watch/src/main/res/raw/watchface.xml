<WatchFace width="450" height="450" shape="CIRCLE">
    <!-- WatchFace Format requires a background -->
    <Scene backgroundColor="#000000">
        <!-- We use an invisible complication or simple tap target to launch the app.
             However, since we want to launch the app on wake anyway, 
             and just show a phone icon, we define it here -->
        
        <!-- Condition to show filled vs outlined icon based on ambient mode -->
        <Condition>
            <Expression name="ambient">
                [IS_AMBIENT]
            </Expression>
            
            <!-- Ambient Mode (Standby): Show dimmed/outlined version -->
            <!-- Since WFF doesn't easily outline vectors on the fly, we just show a dimmed image -->
            <Compare expression="ambient">
                <PartImage x="135" y="135" width="180" height="180" alpha="150">
                    <Image resource="ic_call_24" />
                </PartImage>
            </Compare>

            <!-- Interactive Mode: Show bright version -->
            <Default>
                <PartImage x="135" y="135" width="180" height="180">
                    <Image resource="ic_call_24" />
                </PartImage>
            </Default>
        </Condition>

        <!-- Tap Target to launch our main activity -->
        <ListConfiguration id="1">
            <BoundingBox x="0" y="0" width="450" height="450" />
            <!-- Open the app when tapping the screen -->
        </ListConfiguration>
    </Scene>
</WatchFace>